# ══════════════════════════════════════════════════════════════════════════════
#  SmartzConnect — Full Production Environment Reference
#  ─────────────────────────────────────────────────────
#  VITE_*  keys   →  add to Vercel dashboard (Project → Settings → Env Vars)
#  Non-VITE keys  →  add to Supabase dashboard (Project → Edge Functions → Secrets)
#  SUPABASE_URL / SUPABASE_ANON_KEY are auto-injected by Supabase — skip those.
# ══════════════════════════════════════════════════════════════════════════════


# ── VERCEL ENV VARS (Frontend — VITE_* only) ──────────────────────────────────

# Supabase  →  supabase.com/dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# GetStream Chat  →  getstream.io/dashboard → App → Overview
VITE_STREAM_API_KEY=your-stream-api-key
VITE_STREAM_APP_ID=your-stream-app-id

# LiveKit Video/Audio  →  livekit.io/cloud → Project → Settings → Keys
VITE_LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# OneSignal Push  →  onesignal.com/apps → Your App → Keys & IDs
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id


# ── SUPABASE EDGE FUNCTION SECRETS (Server-side — Supabase dashboard only) ────
#  supabase.com/dashboard → Project → Edge Functions → Manage secrets

# Supabase service role (has admin access — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# GetStream — server-side secret for signing user tokens
STREAM_API_SECRET=your-stream-api-secret

# LiveKit — server-side key pair for signing room tokens
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# OneSignal — REST key for sending push notifications server-side
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# SUFY Object Storage  →  your SUFY dashboard → Bucket → Access Keys
SUFY_ACCESS_KEY_ID=your-sufy-access-key-id
SUFY_SECRET_ACCESS_KEY=your-sufy-secret-access-key
SUFY_BUCKET=your-sufy-bucket-name
SUFY_REGION=your-sufy-region

# Resend (transactional email)  →  resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# Cron secret — random string you choose; used to authenticate the backup cron job
CRON_SECRET=your-random-cron-secret
