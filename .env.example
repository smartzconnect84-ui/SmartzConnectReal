# ── Frontend (Vite) — all VITE_ vars are bundled into the client build ──────────
# Required: Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required: GetStream chat
VITE_STREAM_API_KEY=your-getstream-api-key

# Required: LiveKit WebSocket URL
VITE_LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# Required: OneSignal Web Push (get from OneSignal dashboard → Settings → Keys & IDs)
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id

# Optional: Cloudflare Turnstile bot protection (omit to disable captcha)
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# ── Server-side secrets (Supabase Edge Functions only — NEVER commit) ──────────
# GetStream
STREAM_API_SECRET=your-getstream-api-secret

# LiveKit
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# OneSignal (REST API Key from OneSignal dashboard → Settings → Keys & IDs)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# Supabase admin (for edge functions that need service-role access)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key

# Cloudflare Turnstile (server-side validation)
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
