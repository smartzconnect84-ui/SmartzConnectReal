# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: supabase.com/dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── GetStream Chat ───────────────────────────────────────────────────────────
# Get from: getstream.io/dashboard → App → Overview
VITE_STREAM_API_KEY=your-stream-api-key
VITE_STREAM_APP_ID=your-stream-app-id

# ─── LiveKit Video/Audio ──────────────────────────────────────────────────────
# Get from: livekit.io/cloud → Project → Settings
VITE_LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# ─── OneSignal Push Notifications ────────────────────────────────────────────
# Get from: onesignal.com/apps → Your App → Keys & IDs
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
